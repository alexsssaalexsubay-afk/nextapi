# ── Core ────────────────────────────────────────
APP_ENV=dev
SERVER_ADDR=:8080
DATABASE_URL=postgres://nextapi:nextapi@localhost:5432/nextapi?sslmode=disable
REDIS_ADDR=127.0.0.1:6379

# ── Admin Panel ─────────────────────────────────
# Required for /v1/internal/admin/* and /metrics
ADMIN_TOKEN=
# Comma-separated Clerk sign-in emails allowed to open admin.nextapi.top (operator
# session). Must match the email on the Clerk account (case-insensitive).
ADMIN_EMAILS=279154661@qq.com

# ── First-party auth ────────────────────────────
# Set to "true" to allow self-service signup at POST /v1/auth/signup.
# When unset or "false", only operators can create accounts (admin API or accountctl).
AUTH_SIGNUP_ENABLED=false

# ── Resend (email delivery for admin OTP + notifications) ──
# Without this key, admin high-risk operations (credits.adjust, org.pause, etc.)
# are blocked because the OTP email cannot be delivered.
RESEND_API_KEY=

# ── Clerk (legacy / admin SSO fallback) ─────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ── Upstream video provider ─────────────────────
# PROVIDER_MODE selects the upstream adapter for POST /v1/videos.
#   mock     — deterministic in-memory fake (default; no credentials needed)
#   live     — Volcengine Ark direct  (requires VOLC_API_KEY)
#   seedance_relay — managed Seedance relay
#     (set SEEDANCE_RELAY_API_KEY; never expose in browsers)
#PROVIDER_MODE=mock
# Example for managed Seedance relay:
#PROVIDER_MODE=seedance_relay
#SEEDANCE_RELAY_API_KEY=
PROVIDER_MODE=mock

# ── Volcengine Ark (PROVIDER_MODE=live) ─────────
VOLC_API_KEY=
SEEDANCE_MODEL=seedance-2.0

# ── Managed Seedance relay (PROVIDER_MODE=seedance_relay) ─────────
# Internal operator-provided key. Never expose this to customers or browsers.
SEEDANCE_RELAY_API_KEY=
SEEDANCE_RELAY_BASE_URL=
SEEDANCE_RELAY_MODEL=seedance-2.0-pro
SEEDANCE_RELAY_MODEL_MAP=
SEEDANCE_RELAY_ALLOWED_RESOLUTIONS=480p,720p,1080p
SEEDANCE_RELAY_WEBHOOK_SECRET=
SEEDANCE_RELAY_ASSETS_ENABLED=false

# ── EasyPay / ZPay recharge ─────────────────────
EPAY_PID=
EPAY_KEY=
EPAY_GATEWAY=https://zpayz.cn/submit.php
EPAY_NOTIFY_URL=https://api.nextapi.top/api/pay/notify
EPAY_RETURN_URL=https://app.nextapi.top/billing

# ── Stripe (payments) ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_SUCCESS_URL=https://your-domain.com/billing?success=1
CHECKOUT_CANCEL_URL=https://your-domain.com/billing?cancelled=1

# ── Cloudflare Turnstile (optional, anti-bot for public endpoints) ──
TURNSTILE_SECRET_KEY=

# ── R2 (object storage) ────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional compatibility aliases / custom endpoint.
# R2_ACCESS_KEY=        # alias for R2_ACCESS_KEY_ID
# R2_SECRET_KEY=        # alias for R2_SECRET_ACCESS_KEY
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
