# ── Core ────────────────────────────────────────
APP_ENV=dev
SERVER_ADDR=:8080
DATABASE_URL=postgres://nextapi:nextapi@localhost:5432/nextapi?sslmode=disable
REDIS_ADDR=127.0.0.1:6379

# ── Admin Panel ─────────────────────────────────
# Required for /v1/internal/admin/* and /metrics
ADMIN_TOKEN=
# Comma-separated Clerk sign-in emails allowed to open admin.nextapi.top (operator
# session). Must match the email on the Clerk account (case-insensitive).
ADMIN_EMAILS=279154661@qq.com

# ── Clerk (auth) ────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ── Upstream video provider ─────────────────────
# PROVIDER_MODE selects the upstream adapter for POST /v1/videos.
#   mock     — deterministic in-memory fake (default; no credentials needed)
#   live     — Volcengine Ark direct  (requires VOLC_API_KEY)
#   uptoken  — UpToken relay           (requires UPTOKEN_API_KEY)
PROVIDER_MODE=mock

# ── Volcengine Ark (PROVIDER_MODE=live) ─────────
VOLC_API_KEY=
SEEDANCE_MODEL=seedance-2.0

# ── UpToken (PROVIDER_MODE=uptoken) ─────────────
# Sign in at https://uptoken.cc/login → API Keys → create a key (ut-…).
# UPTOKEN_BASE_URL defaults to https://uptoken.cc/v1.
# UPTOKEN_MODEL is the fallback model when a request omits `model`.
# UPTOKEN_MODEL_MAP can remap public IDs → upstream IDs, e.g.
#   UPTOKEN_MODEL_MAP="seedance-2.0:seedance-2.0-pro,seedance-2.0-fast:seedance-2.0-fast"
UPTOKEN_API_KEY=
UPTOKEN_BASE_URL=https://uptoken.cc/v1
UPTOKEN_MODEL=seedance-2.0-pro
UPTOKEN_MODEL_MAP=

# ── Stripe (payments) ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_SUCCESS_URL=https://your-domain.com/billing?success=1
CHECKOUT_CANCEL_URL=https://your-domain.com/billing?cancelled=1

# ── R2 (object storage) ────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
