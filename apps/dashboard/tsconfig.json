{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "allowJs": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/components/ui/*": [
        "../../packages/ui/src/components/ui/*"
      ],
      "@/components/nextapi/*": [
        "../../packages/ui/src/components/nextapi/*"
      ],
      "@/components/theme-provider": [
        "../../packages/ui/src/components/theme-provider"
      ],
      "@/lib/utils": [
        "../../packages/ui/src/lib/utils"
      ],
      "@/lib/i18n/*": [
        "../../packages/ui/src/lib/i18n/*"
      ],
      "@/hooks/*": [
        "../../packages/ui/src/hooks/*"
      ],
      "@/globals.css": [
        "../../packages/ui/src/globals.css"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
